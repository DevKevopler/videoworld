---
import { getTranslations, type Lang } from '../i18n/translations';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<section class="hero" id="home">
	<div class="hero-backdrop"></div>
	<div class="container hero-inner">
		<span class="eyebrow">{t.hero.eyebrow}</span>
		<h1 class="hero-title">{t.hero.title}</h1>
		<p class="hero-subtitle">{t.hero.subtitle}</p>
		<div class="hero-actions">
			<a href="#contact" class="btn btn-primary">{t.hero.ctaPrimary}</a>
			<a href="#portfolio" class="btn btn-secondary">{t.hero.ctaSecondary}</a>
		</div>
	</div>
	<a href="#services" class="scroll-cue" aria-hidden="true"></a>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding: 8rem 0 4rem;
		overflow: hidden;
	}

	.hero-backdrop {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(ellipse 60% 50% at 70% 20%, rgba(212, 175, 55, 0.12), transparent 60%),
			radial-gradient(ellipse 50% 50% at 20% 80%, rgba(212, 175, 55, 0.08), transparent 60%),
			linear-gradient(180deg, #0a0a0a 0%, #111 60%, #0a0a0a 100%);
	}

	.hero-inner {
		max-width: 760px;
	}

	.hero-title {
		font-size: clamp(2.5rem, 6vw, 4.25rem);
		margin-bottom: 1.5rem;
	}

	.hero-subtitle {
		font-size: 1.15rem;
		color: var(--color-text-muted);
		max-width: 52ch;
		margin-bottom: 2.5rem;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.scroll-cue {
		position: absolute;
		left: 50%;
		bottom: 2rem;
		width: 1.5rem;
		height: 2.5rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		transform: translateX(-50%);
	}

	.scroll-cue::before {
		content: '';
		position: absolute;
		top: 0.4rem;
		left: 50%;
		width: 4px;
		height: 8px;
		background: var(--color-accent);
		border-radius: 999px;
		transform: translateX(-50%);
		animation: scroll-cue-bounce 1.8s ease-in-out infinite;
	}

	@keyframes scroll-cue-bounce {
		0%,
		100% {
			transform: translate(-50%, 0);
			opacity: 1;
		}
		50% {
			transform: translate(-50%, 0.6rem);
			opacity: 0.4;
		}
	}

	@media (max-width: 720px) {
		.scroll-cue {
			display: none;
		}
	}
</style>
