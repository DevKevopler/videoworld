---
interface Props {
	name:
		| 'rings'
		| 'briefcase'
		| 'drone'
		| 'calendar'
		| 'play'
		| 'menu'
		| 'close'
		| 'phone'
		| 'mail'
		| 'pin'
		| 'camera'
		| 'gimbal'
		| 'mic'
		| 'star';
