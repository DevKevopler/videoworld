---
interface Props {
	name: 'rings' | 'briefcase' | 'drone' | 'calendar' | 'play' | 'menu' | 'close' | 'phone' | 'mail' | 'pin';
	class?: string;
}

const { name, class: className } = Astro.props;

const paths: Record<Props['name'], string> = {
	rings:
		'M9 17a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm6.5-8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z',
	briefcase:
		'M4 8h16v10a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V8Zm4 0V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2',
	drone:
		'M12 9v6m-3-3h6M5 5l2.5 2.5M19 5l-2.5 2.5M5 19l2.5-2.5M19 19l-2.5-2.5M3 5h2v2H3V5Zm16 0h2v2h-2V5ZM3 17h2v2H3v-2Zm16 0h2v2h-2v-2Z',
	calendar:
		'M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm0 5h14M8 3v4M16 3v4',
	play: 'M8 5.5v13l11-6.5-11-6.5Z',
	menu: 'M4 7h16M4 12h16M4 17h16',
	close: 'M6 6l12 12M18 6 6 18',
	phone:
		'M6.5 4h3l1.5 4-2 1.5a11 11 0 0 0 5.5 5.5l1.5-2 4 1.5v3a1 1 0 0 1-1 1A15 15 0 0 1 5.5 5a1 1 0 0 1 1-1Z',
	mail: 'M4 6h16v12H4V6Zm0 0 8 7 8-7',
	pin: 'M12 21s7-7.1 7-12a7 7 0 1 0-14 0c0 4.9 7 12 7 12Zm0-9a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z',
};
---

<svg
	class={className}
	width="24"
	height="24"
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.5"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
>
	<path d={paths[name]}></path>
</svg>
