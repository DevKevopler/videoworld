---
import { getTranslations, type Lang } from '../i18n/translations';
import { getBase } from '../lib/url';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const base = getBase();
const homeHref = lang === 'et' ? base : `${base}en/`;
const altHref = lang === 'et' ? `${base}en/` : base;

const navLinks = [
	{ href: '#services', label: t.nav.services, id: 'services' },
	{ href: '#portfolio', label: t.nav.portfolio, id: 'portfolio' },
	{ href: '#testimonials', label: t.nav.testimonials, id: 'testimonials' },
	{ href: '#equipment', label: t.nav.equipment, id: 'equipment' },
	{ href: '#about', label: t.nav.about, id: 'about' },
	{ href: '#contact', label: t.nav.contact, id: 'contact' },
];
---

<aside class="sidebar" id="sidebar">
	<div class="sidebar-inner">
		<a href={homeHref} class="logo" aria-label="Videomaailm">
			<img src={`${base}logo.png`} alt="Videomaailm" class="logo-img" />
		</a>

		<nav class="sidebar-nav" aria-label="Põhinavigatsioon">
			{navLinks.map((link) => (
				<a href={link.href} class="nav-link" data-section={link.id}>
					<span class="nav-indicator"></span>
					<span class="nav-label">{link.label}</span>
				</a>
			))}
		</nav>

		<div class="sidebar-footer">
			<a href={altHref} class="lang-switch">{lang === 'et' ? 'EN' : 'ET'}</a>
			<a href="#contact" class="btn btn-primary cta-btn">{t.nav.cta}</a>
		</div>
	</div>

	<div class="progress-track">
		<div class="progress-fill" id="scroll-progress"></div>
	</div>
</aside>

<button id="sidebar-toggle" class="sidebar-toggle" aria-label="Menüü" aria-expanded="false" aria-controls="sidebar">
	<span class="hamburger">
		<span></span>
		<span></span>
		<span></span>
	</span>
</button>

<div class="sidebar-backdrop" id="sidebar-backdrop"></div>

<style>
	:global(body) {
		padding-left: 220px;
	}

	@media (max-width: 900px) {
		:global(body) {
			padding-left: 0;
		}
	}

	/* Sidebar */
	.sidebar {
		position: fixed;
		top: 0;
		left: 0;
		bottom: 0;
		width: 220px;
		z-index: 100;
		background: var(--color-bg-alt);
		border-right: 1px solid var(--color-border);
		display: flex;
		flex-direction: row;
	}

	.sidebar-inner {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: 2rem 1.5rem;
		overflow-y: auto;
		scrollbar-width: none;
	}

	.sidebar-inner::-webkit-scrollbar {
		display: none;
	}

	/* Logo */
	.logo {
		display: flex;
		align-items: center;
		margin-bottom: 2.5rem;
	}

	.logo-img {
		height: 2.2rem;
		width: auto;
		mix-blend-mode: screen;
		transition: transform 0.25s ease, filter 0.25s ease;
	}

	.logo:hover .logo-img {
		transform: scale(1.06);
		filter: brightness(1.2);
	}

	/* Nav */
	.sidebar-nav {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		flex: 1;
	}

	.nav-link {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.65rem 0.75rem;
		border-radius: 6px;
		color: var(--color-text-muted);
		font-size: 0.9rem;
		transition: color 0.2s ease, background 0.2s ease;
		position: relative;
	}

	.nav-indicator {
		width: 3px;
		height: 0;
		background: var(--color-accent);
		border-radius: 2px;
		transition: height 0.25s ease;
		flex-shrink: 0;
	}

	.nav-link:hover {
		color: var(--color-text);
		background: rgba(255, 255, 255, 0.05);
	}

	.nav-link:hover .nav-indicator {
		height: 14px;
	}

	.nav-link.is-active {
		color: var(--color-accent);
		background: rgba(232, 32, 32, 0.08);
	}

	.nav-link.is-active .nav-indicator {
		height: 20px;
	}

	/* Footer */
	.sidebar-footer {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
		margin-top: 1rem;
	}

	.lang-switch {
		text-align: center;
		border: 1px solid var(--color-border);
		border-radius: 4px;
		padding: 0.4rem;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		color: var(--color-text-muted);
		transition: border-color 0.2s ease, color 0.2s ease;
	}

	.lang-switch:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	.cta-btn {
		width: 100%;
		text-align: center;
		padding: 0.6rem 1rem;
		font-size: 0.82rem;
	}

	/* Vertical progress bar */
	.progress-track {
		width: 2px;
		background: var(--color-border);
		position: relative;
		flex-shrink: 0;
	}

	.progress-fill {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 0%;
		background: var(--color-accent);
		transition: height 0.08s linear;
	}

	/* Mobile toggle */
	.sidebar-toggle {
		display: none;
		position: fixed;
		top: 1rem;
		left: 1rem;
		z-index: 102;
		width: 2.4rem;
		height: 2.4rem;
		align-items: center;
		justify-content: center;
		background: var(--color-bg-alt);
		border: 1px solid var(--color-border);
		border-radius: 6px;
		cursor: pointer;
		transition: border-color 0.2s ease;
	}

	.sidebar-toggle:hover {
		border-color: var(--color-accent);
	}

	.hamburger {
		display: flex;
		flex-direction: column;
		gap: 4px;
		width: 18px;
	}

	.hamburger span {
		display: block;
		height: 1.5px;
		background: var(--color-text);
		border-radius: 2px;
		transition: transform 0.28s ease, opacity 0.2s ease, width 0.25s ease;
		transform-origin: center;
	}

	.hamburger span:nth-child(3) {
		width: 65%;
		align-self: flex-end;
	}

	.sidebar-toggle[aria-expanded='true'] .hamburger span:nth-child(1) {
		transform: translateY(5.5px) rotate(45deg);
	}

	.sidebar-toggle[aria-expanded='true'] .hamburger span:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}

	.sidebar-toggle[aria-expanded='true'] .hamburger span:nth-child(3) {
		width: 100%;
		transform: translateY(-5.5px) rotate(-45deg);
	}

	/* Backdrop */
	.sidebar-backdrop {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.55);
		z-index: 99;
		opacity: 0;
		transition: opacity 0.3s ease;
		backdrop-filter: blur(2px);
		pointer-events: none;
	}

	@media (max-width: 900px) {
		.sidebar-toggle {
			display: flex;
		}

		.sidebar-backdrop {
			display: block;
		}

		.sidebar-backdrop.is-open {
			opacity: 1;
			pointer-events: auto;
		}

		.sidebar {
			transform: translateX(-100%);
			transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
			box-shadow: 4px 0 24px rgba(0, 0, 0, 0.3);
		}

		.sidebar.is-open {
			transform: translateX(0);
		}

		.nav-link {
			opacity: 0;
			transform: translateX(-12px);
			transition: color 0.2s ease, background 0.2s ease, opacity 0.3s ease, transform 0.3s ease;
		}

		.sidebar.is-open .nav-link { opacity: 1; transform: translateX(0); }
		.sidebar.is-open .nav-link:nth-child(1) { transition-delay: 0.04s; }
		.sidebar.is-open .nav-link:nth-child(2) { transition-delay: 0.08s; }
		.sidebar.is-open .nav-link:nth-child(3) { transition-delay: 0.12s; }
		.sidebar.is-open .nav-link:nth-child(4) { transition-delay: 0.16s; }
		.sidebar.is-open .nav-link:nth-child(5) { transition-delay: 0.20s; }
		.sidebar.is-open .nav-link:nth-child(6) { transition-delay: 0.24s; }
	}
</style>

<script>
	const toggle = document.getElementById('sidebar-toggle') as HTMLButtonElement | null;
	const sidebar = document.getElementById('sidebar');
	const backdrop = document.getElementById('sidebar-backdrop');
	const progressFill = document.getElementById('scroll-progress') as HTMLElement | null;

	function openSidebar() {
		sidebar?.classList.add('is-open');
		backdrop?.classList.add('is-open');
		toggle?.setAttribute('aria-expanded', 'true');
		document.body.style.overflow = 'hidden';
	}

	function closeSidebar() {
		sidebar?.classList.remove('is-open');
		backdrop?.classList.remove('is-open');
		toggle?.setAttribute('aria-expanded', 'false');
		document.body.style.overflow = '';
	}

	toggle?.addEventListener('click', () => {
		sidebar?.classList.contains('is-open') ? closeSidebar() : openSidebar();
	});

	backdrop?.addEventListener('click', closeSidebar);

	sidebar?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			if (window.innerWidth <= 900) closeSidebar();
		});
	});

	// Vertical scroll progress
	window.addEventListener('scroll', () => {
		if (progressFill) {
			const docHeight = document.documentElement.scrollHeight - window.innerHeight;
			progressFill.style.height = docHeight > 0 ? `${(window.scrollY / docHeight) * 100}%` : '0%';
		}
	}, { passive: true });

	// Active section
	const sections = document.querySelectorAll<HTMLElement>('section[id]');
	const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link[data-section]');

	const observer = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					navLinks.forEach((link) => {
						link.classList.toggle('is-active', link.dataset.section === entry.target.id);
					});
				}
			}
		},
		{ rootMargin: '-25% 0px -65% 0px' }
	);

	sections.forEach((s) => observer.observe(s));
</script>
